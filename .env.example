# Copy to .env and fill in. See CLAUDE.md. Local-only app — keys stay in this gitignored file.
DATABASE_URL="postgresql://james@localhost:5432/pbx?schema=public"
AUTH_SECRET="generate-with: openssl rand -base64 32"
# AES-256-GCM key that encrypts stored SIP/trunk/voicemail secrets at rest. REQUIRED in prod.
# openssl rand -base64 32
CRED_SECRET=""
# Rotate safely: set CRED_SECRET=<new> + CRED_SECRET_OLD=<old> (comma-separated for multiple),
# then `npm run rotate:cred-secret` to re-encrypt at rest, then clear CRED_SECRET_OLD.
CRED_SECRET_OLD=""
# The console runs on port 3001. (`install.sh` auto-sets this to http://<LAN_IP>:3001.)
APP_URL="http://localhost:3001"

# --- Asterisk ARI (the call engine, in the Lima/Debian VM) ---
ARI_APP="pbx-app"
# ARI REST base. Dev: the VM's reachable IP. Office/prod: 127.0.0.1 (co-located).
ARI_HTTP_URL="http://127.0.0.1:8088"
ARI_USER="pbx"
ARI_PASSWORD=""
# Port our control plane listens on for Asterisk's OUTBOUND WebSocket (Asterisk dials out to us).
ARI_WS_PORT="8090"
# Asterisk realtime tables (ps_*/cdr/cel) live in this schema in the SAME database.
ASTERISK_DB_SCHEMA="asterisk"

# --- Asterisk AMI (reboot / force-provision push over Action: PJSIPNotify) ---
AMI_HOST="127.0.0.1"    # dev: Lima forwards to the guest; prod co-located: 127.0.0.1
AMI_PORT="5038"
AMI_USER="pbx-ctl"      # must equal manager.conf [pbx-ctl]
AMI_PASSWORD=""         # must equal manager.conf secret= (replace CHANGEME_AMI_PASSWORD)

# --- SIP / provisioning ---
SIP_DOMAIN="pbx.local"
# The SIP server address phones register to (the VM's LAN IP in the office). Used in phone configs.
SIP_SERVER_HOST=""
# Browser softphone (WebRTC) WebSocket URL to Asterisk's /ws. Defaults to ws://SIP_SERVER_HOST:8088/ws.
SIP_WS_URL=""
# Derives per-device provisioning tokens (the /provision/<mac> URL secret). openssl rand -base64 32
PROVISION_SECRET=""

# --- Async AI (voicemail + call transcription/summaries) ---
ANTHROPIC_API_KEY=""
CLAUDE_SUMMARY_MODEL="claude-haiku-4-5"
DEEPGRAM_API_KEY=""
# mock | deepgram | whisper  (mock = deterministic offline, no key)
STT_PROVIDER="mock"

# --- Email (voicemail transcripts) ---
# Unset SMTP_HOST → the email seam logs instead of sending (mock, offline, free). Set these to
# deliver voicemail transcripts to the extension's email (e.g. Gmail: smtp.gmail.com:587 + an app
# password; SMTP_SECURE="1" for port 465).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE=""
EMAIL_FROM="PBX <pbx@yourdomain.com>"

# --- Operations: seed password, health alerts, backups (prod supervision) ---
# Seed login password. Unset → the shared demo "password123" (dev only, warns loudly). Set to a
# real secret before seeding a fresh production DB. Rotate existing logins in the Users admin.
SEED_PASSWORD=""
# Where control-plane health alerts go. Unset → the first ADMIN user's email. Delivery uses the
# same SMTP_* seam above (unset SMTP_HOST → the alert is only logged, not emailed).
ALERT_EMAIL=""
# Heartbeat staleness (ms) before the health check alerts; marker file to de-dupe alerts.
HEALTH_STALE_MS="60000"
HEALTH_MARKER="/var/lib/pbx/health-alert.state"
# Daily pg_dump backups (pbx-backup.timer). Directory + how many dumps to keep.
PBX_BACKUP_DIR="/var/backups/pbx"
PBX_BACKUP_KEEP="14"

# --- Call parking (dial the orbit to park, dial the slot to retrieve) ---
PARK_ORBIT="7000"
PARK_SLOT_START="7001"
PARK_SLOT_END="7010"
PARK_RETURN_SECONDS="120"

# Login lockout: after MAX_FAILS failed attempts for an email, reject for LOCK_SECONDS.
LOGIN_MAX_FAILS="5"
LOGIN_LOCK_SECONDS="300"

# E911 on-site notification (Kari's Law). The dialplan's e911-notify.sh POSTs to /api/e911/notify
# with this shared token; the endpoint emails E911_ALERT_EMAIL (falls back to the first ADMIN) via
# the SMTP seam above. Set the SAME token in the VM's /etc/asterisk/e911-notify.env.
E911_NOTIFY_TOKEN=""
E911_ALERT_EMAIL=""

# Offline/dev switches. Leave EMPTY in production.
ALLOW_MOCK=""
# Worker identity (optional; defaults to hostname:pid).
WORKER_ID=""
