# Copy to .env and fill in. See CLAUDE.md. Local-only app — keys stay in this gitignored file.
DATABASE_URL="postgresql://james@localhost:5432/pbx?schema=public"
AUTH_SECRET="generate-with: openssl rand -base64 32"
# AES-256-GCM key that encrypts stored SIP/trunk/voicemail secrets at rest. REQUIRED in prod.
# Rotating it invalidates stored secrets (re-enter them). openssl rand -base64 32
CRED_SECRET=""
APP_URL="http://localhost:3000"

# --- Asterisk ARI (the call engine, in the Lima/Debian VM) ---
ARI_APP="pbx-app"
# ARI REST base. Dev: the VM's reachable IP. Office/prod: 127.0.0.1 (co-located).
ARI_HTTP_URL="http://127.0.0.1:8088"
ARI_USER="pbx"
ARI_PASSWORD=""
# Port our control plane listens on for Asterisk's OUTBOUND WebSocket (Asterisk dials out to us).
ARI_WS_PORT="8090"
# Asterisk realtime tables (ps_*/cdr/cel) live in this schema in the SAME database.
ASTERISK_DB_SCHEMA="asterisk"

# --- SIP / provisioning ---
SIP_DOMAIN="pbx.local"
# The SIP server address phones register to (the VM's LAN IP in the office). Used in phone configs.
SIP_SERVER_HOST=""
# Derives per-device provisioning tokens (the /provision/<mac> URL secret). openssl rand -base64 32
PROVISION_SECRET=""

# --- Async AI (voicemail + call transcription/summaries) ---
ANTHROPIC_API_KEY=""
CLAUDE_SUMMARY_MODEL="claude-haiku-4-5"
DEEPGRAM_API_KEY=""
# mock | deepgram | whisper  (mock = deterministic offline, no key)
STT_PROVIDER="mock"

# Offline/dev switches. Leave EMPTY in production.
ALLOW_MOCK=""
# Worker identity (optional; defaults to hostname:pid).
WORKER_ID=""
