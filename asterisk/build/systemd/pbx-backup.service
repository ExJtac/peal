[Unit]
# One-shot Postgres backup (driven by pbx-backup.timer). Dumps the whole `pbx` DB — both the
# public (app) and asterisk (ps_*/cdr/cel) schemas — since everything lives in one database.
Description=PBX Postgres backup (pg_dump)
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=@PBX_USER@
Group=@PBX_USER@
WorkingDirectory=@PBX_DIR@
EnvironmentFile=@PBX_ENV@
ExecStart=/usr/bin/env bash @PBX_DIR@/scripts/backup-db.sh
